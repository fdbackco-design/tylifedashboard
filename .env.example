# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# TY Life 외부 시스템 연동
# ─────────────────────────────────────────────
# 외부 TY Life 시스템 베이스 URL
TYLIFE_BASE_URL=https://your-tylife-system.example.com

# 세션 쿠키 (실제 로그인 후 브라우저 개발자도구에서 복사)
# 형식: "SESSION_ID=xxxx; OTHER_COOKIE=yyyy"
# 절대 이 파일에 실제 값을 저장하지 마세요
TYLIFE_SESSION_COOKIE=

# 동기화 기본 설정
TYLIFE_SYNC_PAGE_SIZE=50
TYLIFE_SYNC_RATE_LIMIT_MS=500
TYLIFE_SYNC_MAX_RETRIES=3

# ─────────────────────────────────────────────
# 앱 보안
# ─────────────────────────────────────────────
# 수동 sync API 보호용 비밀키 (Bearer 토큰)
SYNC_API_SECRET=your-random-secret-key

# ─────────────────────────────────────────────
# 배포 환경
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
